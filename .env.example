# ══════════════════════════════════════════════════════════════════
#  Variables de Entorno - Frontend
# ══════════════════════════════════════════════════════════════════
# 
# Para desarrollo local:
#   1. Copia este archivo: cp .env.example .env.local
#   2. Completa con tus credenciales de Firebase
#   3. NUNCA subas .env.local a Git
#
# Para producción (Vercel):
#   - Configura estas variables en Settings → Environment Variables
#
# Obtener credenciales de Firebase:
#   → Firebase Console: https://console.firebase.google.com/
#   → Tu proyecto → Configuración → General → Tus apps → SDK
# ══════════════════════════════════════════════════════════════════

# ── API Backend ────────────────────────────────────────────────────
# URL del servidor backend (API REST + WebSockets)
# Desarrollo: http://localhost:3000
# Producción: https://tu-backend.onrender.com
VITE_API_BASE_URL=http://localhost:3000

# ── Firebase Configuration ─────────────────────────────────────────
# API Key de tu proyecto (formato: AIzaSy...)
VITE_FIREBASE_API_KEY=

# Dominio de autenticación (formato: tu-proyecto.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=

# ID del proyecto (debe coincidir con el backend)
VITE_FIREBASE_PROJECT_ID=

# Bucket de almacenamiento (formato: tu-proyecto.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=

# Sender ID para notificaciones (número de 12 dígitos)
VITE_FIREBASE_MESSAGING_SENDER_ID=

# ID de la aplicación web (formato: 1:numero:web:alfanumerico)
VITE_FIREBASE_APP_ID=

# ID de Google Analytics (opcional, formato: G-ALFANUMERICO)
VITE_FIREBASE_MEASUREMENT_ID=
